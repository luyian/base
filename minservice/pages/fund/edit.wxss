/*pages/fund/edit.wxss*/
/* 亮色主题（默认） */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e4e7ed 50%, #dcdfe6 100%);
  padding: 30rpx;
  padding-bottom: 100rpx;
}

.form {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  border: 1rpx solid #e4e7ed;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #303133;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #303133;
  border: 1rpx solid #dcdfe6;
}

.textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #303133;
  border: 1rpx solid #dcdfe6;
}

.holdings-list {
  margin-top: 20rpx;
}

.holding-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.stock-input {
  flex: 1;
  position: relative;
}

.stock-suggestions {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  background: #ffffff;
  border: 1rpx solid #dcdfe6;
  border-radius: 12rpx;
  max-height: 400rpx;
  overflow-y: auto;
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.suggestion-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f7fa;
  font-size: 26rpx;
  color: #303133;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.weight-input {
  display: flex;
  align-items: center;
  width: 180rpx;
}

.weight-input .input {
  width: 140rpx;
}

.percent {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #909399;
}

.remove-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #f56c6c;
  font-size: 32rpx;
  background: #fef0f0;
  border-radius: 50%;
}

.add-btn {
  padding: 24rpx;
  text-align: center;
  color: #409eff;
  font-size: 28rpx;
  border: 2rpx dashed #409eff;
  border-radius: 12rpx;
}

.submit-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 30rpx rgba(64,158,255,0.3);
  border: none;
}

/* 暗色主题 */
.dark-theme .container {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.dark-theme .form {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
}

.dark-theme .label {
  color: rgba(255,255,255,0.9);
}

.dark-theme .input,
.dark-theme .textarea {
  background: rgba(255,255,255,0.08);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.dark-theme .stock-suggestions {
  background: #16213e;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.dark-theme .suggestion-item {
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  color: #fff;
}

.dark-theme .percent {
  color: rgba(255,255,255,0.7);
}

.dark-theme .remove-btn {
  background: rgba(255,107,107,0.15);
}

.dark-theme .add-btn {
  color: #667eea;
  border: 2rpx dashed rgba(102,126,234,0.5);
}

.dark-theme .submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 30rpx rgba(102,126,234,0.4);
}