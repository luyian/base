/*pages/login/login.wxss*/
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* Decorative circles */
.circle {
  position: absolute;
  border-radius: 50%;
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -100rpx;
  right: -100rpx;
  background: rgba(102,126,234,0.3);
  filter: blur(60rpx);
  animation: float 6s ease-in-out infinite;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  top: 200rpx;
  left: 80%;
  background: rgba(118,184,36,0.2);
  filter: blur(60rpx);
  animation: float 8s ease-in-out infinite;
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  bottom: 30%;
  left: 70%;
  background: rgba(16,16,34,0.25);
  filter: blur(80rpx);
  animation: float 10s ease-in-out infinite;
}

/* Header */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  margin-bottom: 80rpx;
  position: relative;
  z-index: 1;
}

.logo-container {
  margin-bottom: 40rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(102,126,234,0.4);
}

.logo-text {
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 40rpx;
}

/* Tab Switcher */
.tab-bar {
  display: flex;
  background: rgba(255,255,255,0.08);
  border-radius: 50rpx;
  padding: 8rpx;
  margin-bottom: 60rpx;
}

.tab {
  padding: 24rpx 60rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  border-radius: 40rpx;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 20rpx rgba(102,126,234,0.4);
}

/* Login Form */
.login-form {
  width: 100%;
}

.input-group {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  color: rgba(255,255,255,0.8);
}

.input {
  flex: 1;
  height: 96rpx;
  padding: 0 30rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
}

/* Button */
.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 30rpx rgba(102,126,234,0.3);
}

.login-btn.wechat {
  background: linear-gradient(135deg, #07c160 0%, #06ad06 100%);
  box-shadow: 0 8rpx 30rpx rgba(7,193,96,0.4);
}

/* Register Link */
.register-link text {
  color: #667eea;
  font-size: 28rpx;
}
/* Captcha */
.captcha-img {
  width: 180rpx;
  height: 70rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  background: #fff;
}
