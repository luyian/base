/* pages/login/login.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #409eff 0%, #67c23a 100%);
  padding: 0 60rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #fff;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-btn {
  width: 600rpx;
  height: 96rpx;
  background: #fff;
  color: #409eff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.tips {
  position: absolute;
  bottom: 100rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.link {
  color: #fff;
  text-decoration: underline;
}