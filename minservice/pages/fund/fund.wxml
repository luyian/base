<!--pages/fund/fund.wxml-->
<view class="container {{themeClass}}">
  <nav-bar title="基金" />
  <!-- Action Bar -->
  <view class="action-bar" style="top: {{navBarTotalHeight}}px;">
    <view class="action-btn" bindtap="goToStock">
      <text>📊 股票列表</text>
    </view>
    <view class="action-btn primary" bindtap="goToCreate" wx:if="{{isAdmin}}">
      <text>+ 创建基金</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
  
  <view class="fund-list" wx:else>
    <view class="fund-item" wx:for="{{funds}}" wx:key="fundId">
      <view class="fund-main" bindtap="goToDetail" data-id="{{item.fundId}}">
        <view class="fund-info">
          <view class="fund-name-row">
            <text class="name">{{item.fundName}}</text>
            <text class="star" wx:if="{{item.inWatchlist}}">★</text>
          </view>
          <text class="code">{{item.fundCode}}</text>
        </view>
        <view class="change {{item.estimatedChangePercent > 0 ? 'up' : (item.estimatedChangePercent < 0 ? 'down' : '')}}">
          <text class="value">{{item.estimatedChangePercent > 0 ? '+' : ''}}{{item.estimatedChangePercent || 0}}%</text>
        </view>
      </view>
      <view class="fund-actions">
        <view class="watchlist-btn" bindtap="toggleWatchlist" data-fund="{{item}}">
          <text class="{{item.inWatchlist ? 'added' : ''}}">{{item.inWatchlist ? '★' : '☆'}}</text>
        </view>
        <view class="action-btn-small" wx:if="{{isAdmin}}" bindtap="goToEdit" data-id="{{item.fundId}}">
          <text>编辑</text>
        </view>
        <view class="action-btn-small delete" wx:if="{{isAdmin}}" bindtap="deleteFund" data-fund="{{item}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>
</view>
