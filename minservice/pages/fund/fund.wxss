/* pages/fund/fund.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.loading { text-align: center; padding: 50rpx; color: #999; }
.fund-list { padding: 20rpx; }
.fund-item { background: #fff; padding: 24rpx 30rpx; margin-bottom: 20rpx; border-radius: 16rpx; display: flex; flex-direction: column; }
.fund-main { display: flex; justify-content: space-between; align-items: center; }
.fund-info { flex: 1; }
.name { font-size: 30rpx; font-weight: 500; display: block; margin-bottom: 8rpx; }
.code { font-size: 24rpx; color: #999; }
.change { font-size: 36rpx; font-weight: bold; }
.up { color: #f56c6c; }
.down { color: #67c23a; }

.watchlist-btn {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
  text-align: right;
}

.watchlist-btn text {
  font-size: 26rpx;
  color: #409eff;
  padding: 10rpx 20rpx;
  border: 1rpx solid #409eff;
  border-radius: 30rpx;
}

.watchlist-btn text.added {
  color: #ffb100;
  border-color: #ffb100;
}