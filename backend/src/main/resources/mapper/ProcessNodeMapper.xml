<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.base.workflow.mapper.ProcessNodeMapper">

    <select id="selectByProcessId" resultType="com.base.workflow.entity.ProcessNode">
        SELECT * FROM sys_process_node
        WHERE process_id = #{processId}
        ORDER BY position_x
    </select>

</mapper>
