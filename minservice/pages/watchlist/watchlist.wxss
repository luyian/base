/* pages/watchlist/watchlist.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.loading { text-align: center; padding: 50rpx; color: #999; }
.watchlist { padding: 20rpx; }
.stock-item { background: #fff; padding: 30rpx; margin-bottom: 20rpx; border-radius: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.stock-info { flex: 1; }
.name { font-size: 30rpx; font-weight: 500; display: block; margin-bottom: 8rpx; }
.code { font-size: 24rpx; color: #999; }
.delete { color: #f56c6c; font-size: 28rpx; }
.empty { text-align: center; padding: 100rpx; color: #999; }