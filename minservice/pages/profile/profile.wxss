/* pages/profile/profile.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.user-header { background: linear-gradient(135deg, #409eff, #67c23a); padding: 60rpx 30rpx; display: flex; flex-direction: column; align-items: center; color: #fff; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 60rpx; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-bottom: 20rpx; }
.nickname { font-size: 36rpx; font-weight: bold; }
.username { font-size: 24rpx; opacity: 0.8; margin-top: 10rpx; }
.menu-list { margin: 20rpx 0; background: #fff; }
.menu-item { padding: 30rpx; border-bottom: 1rpx solid #eee; display: flex; justify-content: space-between; font-size: 30rpx; }
.arrow { color: #999; }
.logout-btn { margin: 40rpx 30rpx; background: #fff; padding: 30rpx; text-align: center; border-radius: 16rpx; }
.logout-btn text { color: #f56c6c; font-size: 30rpx; }
/* Modal */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
.modal { background: #fff; border-radius: 16rpx; width: 600rpx; padding: 40rpx; }
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; }
.modal-content { }
.tip { font-size: 26rpx; color: #666; text-align: center; margin-bottom: 30rpx; }
.input-group { display: flex; align-items: center; background: #f5f5f5; border-radius: 8rpx; padding: 20rpx; margin-bottom: 20rpx; }
.input-icon { margin-right: 20rpx; font-size: 32rpx; }
.input { flex: 1; font-size: 28rpx; }
.modal-btns { display: flex; justify-content: space-between; margin-top: 30rpx; }
.btn { flex: 1; padding: 20rpx 0; font-size: 30rpx; border-radius: 8rpx; }
.btn.cancel { background: #f5f5f5; color: #666; margin-right: 20rpx; }
.btn.confirm { background: #409eff; color: #fff; }
.value { color: #67c23a; }
