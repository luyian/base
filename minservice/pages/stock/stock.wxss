/*pages/stock/stock.wxss*/
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.search-bar {
  padding: 20rpx;
  background: #fff;
}

.search-input {
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  height: 60rpx;
}

.filter-bar {
  padding: 20rpx;
  background: #fff;
  border-bottom: 1px solid #eee;
}

.filter-picker {
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow {
  font-size: 24rpx;
  margin-left: 10rpx;
}

.stock-list {
  padding: 0 20rpx;
}

.stock-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1px solid #f5f5f5;
}

.stock-main {
  display: flex;
  flex: 1;
  align-items: center;
}

.stock-info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.code {
  font-size: 24rpx;
  color: #999;
}

.stock-industry {
  font-size: 24rpx;
  color: #666;
}

.stock-market {
  margin-left: 20rpx;
}

.market-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.market-tag.sh {
  background: #e6f4ea;
  color: #666;
}

.market-tag.sz {
  background: #e6f4ea;
  color: #666;
}

.market-tag.hk {
  background: #f4e6e6;
  color: #666;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 200rpx;
  color: #999;
}