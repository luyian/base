/* pages/fund/fund.wxss */
.container { 
  min-height: 100vh; 
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding-bottom: 40rpx;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(10px);
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
}

.loading { 
  text-align: center; 
  padding: 100rpx; 
  color: rgba(255,255,255,0.6); 
}

.fund-list { 
  padding: 20rpx; 
}

.fund-item { 
  background: rgba(255,255,255,0.08);
  padding: 30rpx; 
  margin-bottom: 20rpx; 
  border-radius: 20rpx; 
  display: flex; 
  flex-direction: column;
  border: 1rpx solid rgba(255,255,255,0.1);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.fund-main { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
}

.fund-info { 
  flex: 1; 
}

.name { 
  font-size: 32rpx; 
  font-weight: 600; 
  display: block; 
  margin-bottom: 8rpx; 
  color: #fff;
}

.code { 
  font-size: 24rpx; 
  color: rgba(255,255,255,0.5); 
}

.change { 
  font-size: 40rpx; 
  font-weight: bold; 
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.up { 
  color: #ff6b6b; 
  background: rgba(255,107,107,0.15);
}

.down { 
  color: #51cf66; 
  background: rgba(81,207,102,0.15);
}

.fund-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.watchlist-btn text {
  font-size: 36rpx;
  color: #ffd43b;
  text-shadow: 0 2rpx 8rpx rgba(255,212,59,0.5);
}

.edit-btn text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 30rpx;
}