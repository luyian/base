/*pages/fund/edit.wxss*/
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.holdings-list {
  margin-top: 20rpx;
}

.holding-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.stock-input {
  flex: 1;
  position: relative;
}

.stock-suggestions {
  position: absolute;
  top: 80rpx;
  left: 0;
  right: 0;
  background: #fff;
  border: 1px solid #eee;
  border-radius: 8rpx;
  max-height: 400rpx;
  overflow-y: auto;
  z-index: 10;
}

.suggestion-item {
  padding: 20rpx 24rpx;
  border-bottom: 1px solid #f5f5f5;
  font-size: 26rpx;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.weight-input {
  display: flex;
  align-items: center;
  width: 180rpx;
}

.weight-input .input {
  width: 140rpx;
}

.percent {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.remove-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #ff4d4f;
  font-size: 32rpx;
}

.add-btn {
  padding: 24rpx;
  text-align: center;
  color: #1890ff;
  font-size: 28rpx;
  border: 1px dashed #1890ff;
  border-radius: 8rpx;
}

.submit-btn {
  margin-top: 40rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}