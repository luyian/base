.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: #FFFFFF;
  transition: background 0.15s ease;
}

.nav-bar.dark {
  background: #0F172A;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 100rpx;
}

.nav-left {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.back-icon {
  font-size: 44rpx;
  font-weight: 300;
  color: #1E293B;
  line-height: 1;
}

.dark .back-icon {
  color: #F1F5F9;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.dark .nav-title {
  color: #F1F5F9;
}

.nav-bar-placeholder {
  width: 100%;
  flex-shrink: 0;
}
