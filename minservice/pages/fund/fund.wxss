/* pages/fund/fund.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.loading { text-align: center; padding: 50rpx; color: #999; }
.fund-list { padding: 20rpx; }
.fund-item { background: #fff; padding: 30rpx; margin-bottom: 20rpx; border-radius: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.fund-info { flex: 1; }
.name { font-size: 30rpx; font-weight: 500; display: block; margin-bottom: 8rpx; }
.code { font-size: 24rpx; color: #999; }
.change { font-size: 36rpx; font-weight: bold; }
.up { color: #f56c6c; }
.down { color: #67c23a; }