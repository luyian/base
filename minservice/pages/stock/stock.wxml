<!--pages/stock/stock.wxml-->
<view class="container {{themeClass}}">
  <!-- Search Bar -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索股票代码/名称" bindconfirm="onSearch" />
  </view>

  <!-- Industry Filter -->
  <view class="filter-bar" wx:if="{{industries.length > 0}}">
    <picker bindchange="onIndustryChange" value="{{industryIndex}}" range="{{industries}}" range-key="name">
      <view class="filter-picker">
        {{industry || '全部行业'}}
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- Stock List -->
  <view class="loading" wx:if="{{loading && stocks.length === 0}}">加载中...</view>
  
  <view class="stock-list" wx:else>
    <view class="stock-item" wx:for="{{stocks}}" wx:key="stockCode" bindtap="goToDetail" data-code="{{item.stockCode}}">
      <view class="stock-main">
        <view class="stock-info">
          <text class="name">{{item.stockName}}</text>
          <text class="code">{{item.stockCode}}</text>
        </view>
        <view class="stock-industry">{{item.industry || '--'}}</view>
      </view>
      <view class="stock-market">
        <text class="market-tag {{item.market === 'SH' ? 'sh' : item.market === 'SZ' ? 'sz' : 'hk'}}">
          {{item.market === 'SH' ? '沪市' : item.market === 'SZ' ? '深市' : '港股'}}
        </text>
      </view>
    </view>
    
    <!-- Load More -->
    <view class="load-more" wx:if="{{stocks.length > 0}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">没有更多了</text>
    </view>
  </view>

  <!-- Empty -->
  <view class="empty" wx:if="{{!loading && stocks.length === 0}}">
    <text>暂无股票数据</text>
  </view>
</view>