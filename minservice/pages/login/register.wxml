<!--pages/login/register.wxml-->
<view class="container">
  <view class="header">
    <text class="title">用户注册</text>
  </view>

  <view class="form">
    <view class="input-group">
      <input class="input" placeholder="请输入用户名（3-50位）" value="{{username}}" bindinput="onUsernameInput" />
    </view>
    <view class="input-group">
      <input class="input password" type="password" placeholder="请输入密码（6-20位）" value="{{password}}" bindinput="onPasswordInput" />
    </view>
    <view class="input-group">
      <input class="input password" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
    </view>
    <view class="input-group">
      <input class="input" placeholder="昵称（可选）" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>
    <view class="input-group">
      <input class="input" type="number" placeholder="手机号（可选）" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <button class="register-btn" bindtap="handleRegister" loading="{{loading}}">
      <text wx:if="{{!loading}}">注册</text>
      <text wx:else>注册中...</text>
    </button>

    <view class="login-link" bindtap="goToLogin">
      <text>已有账号？立即登录</text>
    </view>
  </view>
</view>