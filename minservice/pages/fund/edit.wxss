/*pages/fund/edit.wxss*/
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 30rpx;
  padding-bottom: 100rpx;
}

.form {
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.holdings-list {
  margin-top: 20rpx;
}

.holding-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.stock-input {
  flex: 1;
  position: relative;
}

.stock-suggestions {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  background: #16213e;
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 12rpx;
  max-height: 400rpx;
  overflow-y: auto;
  z-index: 10;
}

.suggestion-item {
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  font-size: 26rpx;
  color: #fff;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.weight-input {
  display: flex;
  align-items: center;
  width: 180rpx;
}

.weight-input .input {
  width: 140rpx;
}

.percent {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

.remove-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #ff6b6b;
  font-size: 32rpx;
  background: rgba(255,107,107,0.15);
  border-radius: 50%;
}

.add-btn {
  padding: 24rpx;
  text-align: center;
  color: #667eea;
  font-size: 28rpx;
  border: 2rpx dashed rgba(102,126,234,0.5);
  border-radius: 12rpx;
}

.submit-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 30rpx rgba(102,126,234,0.4);
  border: none;
}