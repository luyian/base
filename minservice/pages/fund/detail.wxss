/* pages/fund/detail.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.loading { text-align: center; padding: 50rpx; color: #999; }
.fund-header { background: linear-gradient(135deg, #409eff, #67c23a); color: #fff; padding: 40rpx 30rpx; }
.name { font-size: 36rpx; font-weight: bold; display: block; }
.code { font-size: 24rpx; opacity: 0.8; }
.change { margin-top: 20rpx; }
.value { font-size: 60rpx; font-weight: bold; }
.up { color: #f56c6c; }
.down { color: #fff; }
.section-title { padding: 30rpx; font-size: 30rpx; font-weight: 500; }
.holding-list { padding: 0 20rpx; }
.holding-item { background: #fff; padding: 30rpx; margin-bottom: 2rpx; display: flex; justify-content: space-between; }
.stock-info { flex: 1; }
.stock-name { font-size: 28rpx; display: block; }
.stock-code { font-size: 24rpx; color: #999; }
.stock-data { text-align: right; }
.price { font-size: 28rpx; display: block; }
.change { font-size: 26rpx; display: block; }
.weight { font-size: 22rpx; color: #999; display: block; }