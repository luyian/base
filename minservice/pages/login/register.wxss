/*pages/login/register.wxss*/
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  padding: 60rpx 40rpx;
}

.header {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.form {
  width: 100%;
}

.input-group {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 30rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.input::placeholder {
  color: rgba(255,255,255,0.4);
}

.register-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(102,126,234,0.4);
  border: none;
  margin-top: 40rpx;
}

.login-link {
  text-align: center;
  margin-top: 40rpx;
}

.login-link text {
  color: #667eea;
  font-size: 28rpx;
}