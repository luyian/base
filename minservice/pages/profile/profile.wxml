<!--pages/profile/profile.wxml-->
<view class="container {{themeClass}}">
  <nav-bar title="我的" />
  <!-- User Info -->
  <view class="user-header">
    <view class="avatar">
      <text>{{userInfo.nickname || '用户'}}</text>
    </view>
    <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
    <text class="username">@{{userInfo.username || ''}}</text>
  </view>

  <!-- Menu -->
  <view class="menu-list">
    <!-- 主题切换 -->
    <view class="menu-item" bindtap="toggleTheme">
      <text>主题模式</text>
      <view class="theme-switch">
        <text class="{{isDarkTheme ? '' : 'active'}}">☀ 亮色</text>
        <text class="{{isDarkTheme ? 'active' : ''}}">🌙 暗色</text>
      </view>
    </view>
    <view class="menu-item" bindtap="bindWechat" wx:if="{{!userInfo.wxOpenid}}">
      <text>绑定微信</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="unbindWechat" wx:else>
      <text>解绑微信</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>通知设置</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>关于我们</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- Logout -->
  <view class="logout-btn" bindtap="logout">
    <text>退出登录</text>
  </view>
</view>
<!-- Bind WeChat Modal -->
<view class="modal-mask" wx:if="{{showBindModal}}">
  <view class="modal">
    <view class="modal-title">绑定微信</view>
    <view class="modal-content">
      <view class="tip">请输入当前账号的用户名和密码进行绑定</view>
      
      <view class="input-group">
        <view class="input-icon">👤</view>
        <input class="input" placeholder="用户名" value="{{bindUsername}}" bindinput="onBindUsernameInput" />
      </view>
      <view class="input-group">
        <view class="input-icon">🔒</view>
        <input class="input password" type="password" placeholder="密码" value="{{bindPassword}}" bindinput="onBindPasswordInput" />
      </view>
      
      <view class="modal-btns">
        <button class="btn cancel" bindtap="closeBindModal">取消</button>
        <button class="btn confirm" bindtap="confirmBind" loading="{{binding}}">确认绑定</button>
      </view>
    </view>
  </view>
</view>
