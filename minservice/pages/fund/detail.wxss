/*pages/fund/detail.wxss*/
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  color: #fff;
  padding-bottom: 40rpx;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: rgba(255,255,255,0.6);
}

.fund-header {
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
  padding: 40rpx;
  margin: 30rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fund-header .name {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.fund-header .code {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 30rpx;
}

.fund-header .change {
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  font-size: 48rpx;
  font-weight: bold;
}

.fund-header .change.up {
  background: rgba(255,107,107,0.2);
  color: #ff6b6b;
  box-shadow: 0 4rpx 20rpx rgba(255,107,107,0.3);
}

.fund-header .change.down {
  background: rgba(81,207,102,0.2);
  color: #51cf66;
  box-shadow: 0 4rpx 20rpx rgba(81,207,102,0.3);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  padding: 30rpx;
  color: rgba(255,255,255,0.9);
}

.holding-list {
  padding: 0 30rpx;
}

.holding-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255,255,255,0.06);
  padding: 30rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.stock-info {
  display: flex;
  flex-direction: column;
}

.stock-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
}

.stock-code {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 6rpx;
}

.stock-data {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.change {
  font-size: 26rpx;
  margin: 6rpx 0;
}

.change.up { color: #ff6b6b; }
.change.down { color: #51cf66; }

.weight {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}