/* pages/index/index.wxss - 简基小程序首页样式 */
/* 亮色主题 */
page {
  --primary: #3B82F6;
  --primary-light: #EFF6FF;
  --success: #10B981;
  --success-light: #ECFDF5;
  --danger: #EF4444;
  --danger-light: #FEF2F2;
  --bg: #F5F7FA;
  --card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  --shadow: 0 1px 3px rgba(0, 0, 0, 0.04), 0 4px 12px rgba(0, 0, 0, 0.03);
  --shadow-hover: 0 4px 12px rgba(59, 130, 246, 0.15);
  
  background: var(--bg);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFC 100%);
  padding: 40rpx 32rpx 48rpx;
  border-bottom-left-radius: 32rpx;
  border-bottom-right-radius: 32rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
  display: block;
  position: relative;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
  position: relative;
}

.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-tertiary);
}

.loading {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.fund-list { padding: 24rpx; }

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx 24rpx;
  font-size: 28rpx;
}

.section-title text:first-child {
  font-weight: 600;
  color: var(--text-primary);
  font-size: 30rpx;
  letter-spacing: -0.3rpx;
}

.section-title .more { color: var(--primary); font-size: 24rpx; font-weight: 500; }
.section-title .update-time { color: var(--text-tertiary); font-size: 22rpx; }

.watchlist { margin-bottom: 16rpx; }
.watchlist-card { position: relative; }
.watchlist-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  background: linear-gradient(180deg, #F59E0B 0%, #FBBF24 100%);
  border-radius: 3rpx;
}

.fund-name-row { display: flex; align-items: center; gap: 8rpx; }
.star { color: #F59E0B; font-size: 26rpx; }

.fund-card { 
  background: var(--card);
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx; 
  border-radius: 20rpx; 
  display: flex; 
  justify-content: space-between;
  align-items: center;
  box-shadow: var(--shadow);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.fund-card:active { transform: scale(0.992); box-shadow: var(--shadow-hover); }
.fund-info { flex: 1; min-width: 0; }

.fund-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.fund-code { font-size: 24rpx; color: var(--text-tertiary); letter-spacing: 0.5rpx; }

.fund-change {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  min-width: 110rpx;
  font-weight: 600;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.fund-change.positive { background: var(--success-light); color: var(--success); }
.fund-change.negative { background: var(--danger-light); color: var(--danger); }
.fund-change.zero { background: var(--bg); color: var(--text-tertiary); }

.empty { text-align: center; padding: 120rpx 40rpx; color: var(--text-tertiary); font-size: 28rpx; }

/* 刷新按钮 - 精致流光风格 */
.refresh-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  height: 80rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 50%, #3B82F6 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 
    0 4rpx 16rpx rgba(59, 130, 246, 0.3),
    0 0 0 1rpx rgba(255, 255, 255, 0.1) inset;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
  z-index: 100;
}

