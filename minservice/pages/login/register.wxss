/*pages/login/register.wxss*/
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -50rpx;
  left: 20%;
  background: rgba(102,126,234,0.2);
  filter: blur(60rpx);
}

.circle-2 {
  width: 250rpx;
  height: 250rpx;
  bottom: 20%;
  right: 20%;
  background: rgba(118,75,162,0.2);
  filter: blur(50rpx);
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

.form {
  width: 100%;
}

.input-group {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.input-icon {
  font-size: 32rpx;
  padding-left: 24rpx;
  color: rgba(255,255,255,0.7);
}

.input {
  flex: 1;
  height: 96rpx;
  padding: 0 30rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
}

.register-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(102,126,234,0.3);
  border: none;
  margin-top: 40rpx;
}

.login-link {
  text-align: center;
  margin-top: 40rpx;
}

.login-link text {
  color: #667eea;
  font-size: 28rpx;
}