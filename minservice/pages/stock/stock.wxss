/*pages/stock/stock.wxss*/
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.search-bar {
  padding: 30rpx;
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(10px);
}

.search-input {
  padding: 24rpx 30rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.search-input::placeholder {
  color: rgba(255,255,255,0.4);
}

.filter-bar {
  padding: 20rpx 30rpx;
  background: rgba(255,255,255,0.03);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.filter-picker {
  padding: 20rpx 30rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow {
  font-size: 20rpx;
  margin-left: 10rpx;
  color: rgba(255,255,255,0.5);
}

.stock-list {
  padding: 20rpx 30rpx;
}

.stock-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: rgba(255,255,255,0.06);
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.stock-main {
  display: flex;
  flex: 1;
  align-items: center;
}

.stock-info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.code {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 6rpx;
}

.stock-industry {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  margin-left: 20rpx;
}

.stock-market {
  margin-left: 20rpx;
}

.market-tag {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.market-tag.sh {
  background: rgba(102,126,234,0.2);
  color: #a5b4fc;
}

.market-tag.sz {
  background: rgba(34,211,238,0.2);
  color: #22d3ee;
}

.market-tag.hk {
  background: rgba(251,191,36,0.2);
  color: #fbbf24;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: rgba(255,255,255,0.4);
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 200rpx;
  color: rgba(255,255,255,0.4);
}