<!--pages/stock/stock.wxml-->
<view class="container {{themeClass}}">
  <nav-bar title="股票列表" back="{{true}}" />
  <!-- Search Bar -->
  <view class="search-bar" style="top: {{navBarTotalHeight}}px;">
    <input class="search-input" placeholder="搜索股票代码/名称" bindconfirm="onSearch" />
    <view class="add-btn" bindtap="showAddModal" wx:if="{{isAdmin}}">+ 新增</view>
  </view>


  <!-- Industry Filter -->
  <view class="filter-bar" wx:if="{{industries.length > 0}}">
    <picker bindchange="onIndustryChange" value="{{industryIndex}}" range="{{industries}}" range-key="name">
      <view class="filter-picker">
        {{industry || '全部行业'}}
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- Stock List -->
  <view class="loading" wx:if="{{loading && stocks.length === 0}}">加载中...</view>
  
  <view class="stock-list" wx:else>
    <view class="stock-item" wx:for="{{stocks}}" wx:key="stockCode">
      <view class="stock-main" bindtap="goToDetail" data-code="{{item.stockCode}}">
        <view class="stock-info">
          <text class="name">{{item.stockName}}</text>
          <text class="code">{{item.stockCode}}</text>
        </view>
        <view class="stock-industry">{{item.industry || '--'}}</view>
      </view>
      <view class="stock-right">
        <view class="market-tag {{item.market === 'SH' ? 'sh' : item.market === 'SZ' ? 'sz' : 'hk'}}">
          {{item.market === 'SH' ? '沪市' : item.market === 'SZ' ? '深市' : '港股'}}
        </view>
        <view class="edit-btn" wx:if="{{isAdmin}}" bindtap="showEditModal" data-stock="{{item}}">编辑</view>
      </view>
    </view>
    
    <!-- Load More -->
    <view class="load-more" wx:if="{{stocks.length > 0}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">没有更多了</text>
    </view>
  </view>

  <!-- Empty -->
  <view class="empty" wx:if="{{!loading && stocks.length === 0}}">
    <text>暂无股票数据</text>
  </view>

  <!-- Add Stock Modal -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="hideAddModal"></view>
  <view class="modal" wx:if="{{showAddModal}}">
    <view class="modal-title">新增股票</view>
    <view class="modal-content">
      <view class="form-item">
        <text class="label">股票代码 *</text>
        <input class="input" value="{{newStock.stockCode}}" placeholder="如: 600000" bindinput="onStockCodeChange" />
      </view>
      <view class="form-item">
        <text class="label">股票名称 *</text>
        <input class="input" value="{{newStock.stockName}}" placeholder="如: 浦发银行" bindinput="onStockNameChange" />
      </view>
      <view class="form-item">
        <text class="label">市场</text>
        <picker bindchange="onMarketChange" value="{{marketIndex}}" range="{{markets}}">
          <view class="picker">{{newStock.market || '请选择'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">行业</text>
        <input class="input" value="{{newStock.industry}}" placeholder="如: 银行" bindinput="onIndustryChangeInput" />
      </view>
    </view>
    <view class="modal-btns">
      <button class="btn cancel" bindtap="hideAddModal">取消</button>
      <button class="btn confirm" bindtap="submitAddStock" loading="{{submitting}}">确定</button>
    </view>
  </view>

  <!-- Edit Stock Modal -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="hideEditModal"></view>
  <view class="modal" wx:if="{{showEditModal}}">
    <view class="modal-title">编辑股票</view>
    <view class="modal-content">
      <view class="form-item">
        <text class="label">股票代码</text>
        <input class="input disabled-input" value="{{editStock.stockCode}}" disabled />
      </view>
      <view class="form-item">
        <text class="label">股票名称 *</text>
        <input class="input" value="{{editStock.stockName}}" placeholder="如: 浦发银行" bindinput="onEditStockNameChange" />
      </view>
      <view class="form-item">
        <text class="label">市场</text>
        <picker bindchange="onEditMarketChange" value="{{editMarketIndex}}" range="{{markets}}">
          <view class="picker">{{editStock.market || '请选择'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">行业</text>
        <input class="input" value="{{editStock.industry}}" placeholder="如: 银行" bindinput="onEditIndustryChange" />
      </view>
    </view>
    <view class="modal-btns">
      <button class="btn cancel" bindtap="hideEditModal">取消</button>
      <button class="btn confirm" bindtap="submitEditStock" loading="{{submitting}}">保存</button>
    </view>
  </view>
</view>