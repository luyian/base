<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.base.workflow.mapper.ProcessNodeRelationMapper">

    <select id="selectByProcessId" resultType="com.base.workflow.entity.ProcessNodeRelation">
        SELECT * FROM sys_process_node_relation
        WHERE process_id = #{processId}
    </select>

</mapper>
