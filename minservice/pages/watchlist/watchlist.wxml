<!--pages/watchlist/watchlist.wxml-->
<view class="container">
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  
  <view class="watchlist" wx:else>
    <view class="stock-item" wx:for="{{watchlist}}" wx:key="id">
      <view class="stock-info">
        <text class="name">{{item.stockName}}</text>
        <text class="code">{{item.market}}-{{item.stockCode}}</text>
      </view>
      <view class="actions">
        <text class="delete" bindtap="removeStock" data-id="{{item.id}}">删除</text>
      </view>
    </view>
    
    <view wx:if="{{watchlist.length === 0}}" class="empty">
      <text>暂无自选股</text>
    </view>
  </view>
</view>