/* 刷新按钮 - 精致流光风格 */
.refresh-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  height: 80rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 50%, #3B82F6 100%);
  background-size: 200% 100%;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 
    0 4rpx 16rpx rgba(59, 130, 246, 0.3),
    0 0 0 1rpx rgba(255, 255, 255, 0.1) inset;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 100;
  overflow: hidden;
}

/* 流光效果 */
.refresh-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

/* 刷新图标 - 去掉点击旋转 */
.refresh-icon {
  font-size: 28rpx;
}

/* 加载中动画 */
.refresh-btn.loading .refresh-icon {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 点击缩放效果保留 */
.refresh-btn:active { 
  transform: translateX(-50%) scale(0.96);
  box-shadow: 
    0 2rpx 8rpx rgba(59, 130, 246, 0.2),
    0 0 0 1rpx rgba(255, 255, 255, 0.15) inset;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fund-card { animation: fadeInUp 0.4s ease-out backwards; }
.fund-card:nth-child(1) { animation-delay: 0.05s; }
.fund-card:nth-child(2) { animation-delay: 0.1s; }
.fund-card:nth-child(3) { animation-delay: 0.15s; }
.fund-card:nth-child(4) { animation-delay: 0.2s; }
.fund-card:nth-child(5) { animation-delay: 0.25s; }
.fund-card:nth-child(6) { animation-delay: 0.3s; }

.fund-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.fund-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fund-info {
  flex: 1;
}

.fund-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.fund-name-row .name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.fund-name-row .star {
  color: #f59e0b;
  font-size: 28rpx;
}

.fund-code {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.change {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.change.up {
  background: #fef2f2;
  color: #ef4444;
}

.change.down {
  background: #f0fdf4;
  color: #22c55e;
}

/* 暗色主题适配 */
.dark-theme .fund-item {
  background: #1f2937;
}

.dark-theme .fund-name-row .name {
  color: #f3f4f6;
}

.dark-theme .change.up {
  background: rgba(239, 68, 68, 0.15);
}

.dark-theme .change.down {
  background: rgba(34, 197, 94, 0.15);
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #9ca3af;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
}